        // Calcular KPIs Iniciais
        let qtdDentro = 0, qtdAbaixo = 0, qtdAcima = 0;
        dadosRendimento.forEach(d => {
            if (d.Status_Rendimento === "Dentro do Esperado") qtdDentro++;
            if (d.Status_Rendimento === "Abaixo do Esperado") qtdAbaixo++;
            if (d.Status_Rendimento === "Acima do Esperado") qtdAcima++;
        });

        document.getElementById('kpi-total').innerText = dadosRendimento.length;
        document.getElementById('kpi-dentro').innerText = qtdDentro;
        document.getElementById('kpi-abaixo').innerText = qtdAbaixo;
        document.getElementById('kpi-acima').innerText = qtdAcima;

        // Gráfico 1: Status Geral (Doughnut)
        new Chart(document.getElementById('chartStatus').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Dentro do Esperado', 'Abaixo (Alerta)', 'Acima (Excelente)'],
                datasets: [{
                    data: [qtdDentro, qtdAbaixo, qtdAcima],
                    backgroundColor: ['#10b981', '#f43f5e', '#3b82f6'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        // Gráfico 2: Piores (Bar Horizontal)
        const piores = dadosRendimento.filter(d => d.Status_Rendimento === "Abaixo do Esperado")
                                      .sort((a,b) => a.Km_Por_Litro - b.Km_Por_Litro).slice(0, 5);
        new Chart(document.getElementById('chartPiores').getContext('2d'), {
            type: 'bar',
            data: {
                labels: piores.map(d => d.Placa_Combustivel),
                datasets: [{
                    label: 'Rendimento (Km/Litro)',
                    data: piores.map(d => d.Km_Por_Litro),
                    backgroundColor: '#f43f5e',
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { x: { title: { display: true, text: 'Km / Litro' } } }
            }
        });

        // Preencher Tabela
        const tbody = document.getElementById('tabela-dados');
        function renderTabela(dados) {
            tbody.innerHTML = '';
            dados.forEach(linha => {
                const tr = document.createElement('tr');
                tr.className = "border-b border-gray-200 hover:bg-slate-50 transition-colors";
                
                // Definir cor do badge de status
                let badgeColor = "bg-emerald-100 text-emerald-800";
                if (linha.Status_Rendimento === "Abaixo do Esperado") badgeColor = "bg-rose-100 text-rose-800 font-bold";
                if (linha.Status_Rendimento === "Acima do Esperado") badgeColor = "bg-blue-100 text-blue-800";

                tr.innerHTML = `
                    <td class="py-3 px-4 whitespace-nowrap">${linha.Secretaria}</td>
                    <td class="py-3 px-4 font-bold text-slate-800">${linha.Placa_Combustivel}</td>
                    <td class="py-3 px-4 text-xs text-gray-500">${linha.Veiculo_Rastreador}</td>
                    <td class="py-3 px-4 text-right">${linha.Km_Total.toLocaleString('pt-BR')} km</td>
                    <td class="py-3 px-4 text-right">${linha.Litros_Consumidos.toLocaleString('pt-BR')} L</td>
                    <td class="py-3 px-4 text-right font-semibold">${linha.Km_Por_Litro.toFixed(2)}</td>
                    <td class="py-3 px-4 text-center">
                        <span class="px-2 py-1 rounded-full text-xs ${badgeColor}">${linha.Status_Rendimento}</span>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        renderTabela(dadosRendimento);

        // Filtro de Busca
        function filtrarTabela() {
            const termo = document.getElementById('searchInput').value.toLowerCase();
            const dadosFiltrados = dadosRendimento.filter(d => 
                d.Placa_Combustivel.toLowerCase().includes(termo) ||
                d.Veiculo_Rastreador.toLowerCase().includes(termo) ||
                d.Secretaria.toLowerCase().includes(termo)
            );
            renderTabela(dadosFiltrados);
        }
    </script>
